# ============================================================
# PM Assistant — EXEMPLE DE CONFIGURATION (.env.example)
# ============================================================
# INSTRUCTIONS : Copiez ce fichier sous le nom '.env' et 
# remplissez les variables avec vos propres clés.

# ── LLM OpenRouter ───────────────────────────────────────────
LLM_PROVIDER=openrouter
# Obtenez votre clé sur : https://openrouter.ai/keys
OPENROUTER_API_KEY=votre_cle_openrouter_ici

# ── LLM Groq (Agent Analyse — 14400 req/jour gratuit) ────────
# Obtenez votre clé sur : https://console.groq.com/keys
GROQ_API_KEY=votre_cle_groq_ici

# ── Modèles par agent ─────────────────────────────────────────
# Superviseur — léger et rapide (OpenRouter)
LLM_SUPERVISOR=liquid/lfm-2.5-1.2b-thinking:free

# Analyse — Groq Llama 70B (14400 req/jour, zéro 429)
LLM_ANALYSE=llama-3.3-70b-versatile

# Rapporteur — OpenRouter
LLM_RAPPORTEUR=arcee-ai/trinity-mini:free

# Fallback — Modèle de secours
LLM_FALLBACK=meta-llama/llama-3.1-405b:free

# ── Redmine ───────────────────────────────────────────────────
REDMINE_URL=http://localhost:3000
REDMINE_API_KEY=votre_cle_api_redmine_ici

# ── Base de données PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://utilisateur:motdepasse@localhost:5432/nom_db

# ── Application ───────────────────────────────────────────────
APP_NAME="PM Assistant - Youssef"
SECRET_KEY=generez_une_cle_securisee_ici
DEBUG=True